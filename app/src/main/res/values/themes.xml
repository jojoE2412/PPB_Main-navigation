<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Navigation" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Warna Utama -->
        <item name="colorPrimary">@color/yellow_primary</item>
        <item name="colorOnPrimary">@color/black</item>
        
        <!-- Latar Belakang & Permukaan -->
        <item name="android:windowBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>

        <!-- PENTING: Warna teks utama (untuk Menu Dropdown) -->
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/gray_text</item>

        <item name="colorSecondaryContainer">@color/yellow_light</item>
        <item name="colorOnSecondaryContainer">@color/black</item>
    </style>

    <style name="Theme.Navigation" parent="Base.Theme.Navigation" />

    <style name="RoundedImageView">
        <item name="cornerSize">16dp</item>
    </style>
</resources>
